{
  "name": "wogc-frontend",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview --host 0.0.0.0 --port 4173",
    "test:unit": "vitest run unit_tests",
    "test:api": "vitest run API_tests",
    "test:all": "vitest run",
    "test:component": "playwright test -c playwright-component.config.ts",
    "test:e2e": "playwright test -c playwright-ct.config.ts"
  },
  "dependencies": {
    "@reduxjs/toolkit": "^2.6.1",
    "dexie": "^4.0.11",
    "file-saver": "^2.0.5",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-redux": "^9.2.0",
    "react-router-dom": "^6.28.1"
  },
  "devDependencies": {
    "@playwright/experimental-ct-react": "^1.54.2",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/file-saver": "^2.0.7",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "fake-indexeddb": "^6.2.3",
    "jsdom": "^25.0.1",
    "typescript": "^5.7.3",
    "vite": "^6.0.7",
    "vitest": "^2.1.8"
  }
}
